msgid "Remove Background (rembg)"
msgstr "Supprimer l'arrière-plan (rembg)"

msgid "Removes the background from the active layer using rembg AI"
msgstr "Supprime l'arrière-plan du calque actif en utilisant l'IA rembg"

msgid "Temporarily exports the layer, applies rembg to make the background transparent, then imports it as a new layer."
msgstr "Exporte temporairement le calque, applique rembg pour rendre le fond transparent, puis l'importe comme nouveau calque."

msgid "The 'rembg' or 'Pillow' library is not installed in GIMP's Python environment.\nPlease run: pip install rembg pillow"
msgstr "La bibliothèque 'rembg' ou 'Pillow' n'est pas installée dans l'environnement Python de GIMP.\nVeuillez exécuter : pip install rembg pillow"

msgid "rembg missing"
msgstr "rembg manquant"

msgid "Please select exactly one layer."
msgstr "Veuillez sélectionner exactement un seul calque."

msgid "Invalid selection"
msgstr "Sélection invalide"

msgid "Exporting layer..."
msgstr "Exportation du calque..."

msgid "Failed to temporarily export the layer."
msgstr "Échec de l'exportation temporaire du calque."

msgid "Analyzing image with rembg AI..."
msgstr "Analyse de l'image avec l'IA rembg..."

msgid "Unexpected type returned by rembg: {}"
msgstr "Type inattendu retourné par rembg : {}"

msgid "Importing result..."
msgstr "Importation du résultat..."

msgid " (no background)"
msgstr " (sans fond)"

msgid "Failed to import the cutout layer: {}"
msgstr "Échec de l'importation du calque détouré : {}"

msgid "Error during processing: {}"
msgstr "Erreur lors du traitement : {}"